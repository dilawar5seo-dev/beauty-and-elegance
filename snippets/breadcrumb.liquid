<style>
  .breadcrumb {
    font-size: 14px;
    font-weight: 400;
    line-height: 0.9;
    margin-bottom: 2rem;
    letter-spacing: -0.1px;
  }

  .breadcrumb a.greyed-out{
    color: #8D8D8D;
  }

  .breadcrumb a {
    text-decoration: none;
    color: #000000;
  }


  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb span {
    margin: 0px;
    color: #000000;
    line-height:1;
  }
  .breadcrumb-svg {
    padding: 0 0.5rem;
  }
  .breadcrumb-svg svg{
    vertical-align:middle;
    }
    @media (max-width: 749px) {
       .breadcrumb {
         margin-bottom:10px;
       }
    }
</style>

{% assign collection_handle = collection.handle | default: product.collections.first.handle %}
<nav class="breadcrumb">
  <a class="greyed-out" href="{{ routes.root_url }}">Home</a>
  {% if collection_handle %}
    <span class="breadcrumb-svg light">
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="15" viewBox="0 0 8 15" fill="none">
        <path d="M1.50781 14.3984H0.078125L6.47656 0H7.90625L1.50781 14.3984Z" fill="black"/>
      </svg>
    </span>
    <a class="greyed-out" href="{{ routes.collections_url }}/{{ collection_handle }}">
      {{- collection_handle | capitalize -}}
    </a>
  {% endif %}
  <span class="breadcrumb-svg">
    <svg xmlns="http://www.w3.org/2000/svg" width="8" height="15" viewBox="0 0 8 15" fill="none">
      <path d="M1.50781 14.3984H0.078125L6.47656 0H7.90625L1.50781 14.3984Z" fill="black"/>
    </svg>
  </span>
  <span>{{ product.title | truncate: 30 }}</span>
</nav>
