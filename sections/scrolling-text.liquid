{{ 'section-scrolling-icons.css' | asset_url | stylesheet_tag }}

{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
     .scrolling-icons {
    overflow: hidden;
    width: 100%;
    position: relative;
  }

 .scrolling-icons__track {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  width: max-content;
  direction: ltr;
  animation: marquee-scroll {{ section.settings.speed }}s linear infinite;
  will-change: transform;
}

html[dir="rtl"] .scrolling-icons__track {
  animation-direction: reverse;
}

  .scrolling-icons__item {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    white-space: nowrap;
    padding-right: 40px;
  }

  .scrolling-icons__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .scrolling-icons__icon svg {
    width: 20px;
    height: 20px;
  }

  .scrolling-icons__text {
    font-size: 16px;
    line-height: 1;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .scrolling-icons__item {
      padding-right: 24px;
    }

    .scrolling-icons__text {
      font-size: 14px;
    }
  }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="scrolling-icons section-{{ section.id }}-padding">
    <div class="scrolling-icons__track">
      {% for i in (1..12) %}
        {% for block in section.blocks %}
          <div class="scrolling-icons__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="scrolling-icons__icon">
                {{ block.settings.icon }}
              </div>
            {% endif %}

            {% if block.settings.text != blank %}
              <span class="scrolling-icons__text">
                {{ block.settings.text }}
              </span>
            {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scrolling Icons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 100,
      "step": 1,
      "unit": "s",
      "label": "Scroll speed",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Worldwide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Icons",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
