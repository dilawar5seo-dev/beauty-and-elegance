{% style %}
    #shopify-section-{{ section.id }}.collection-banners-container{
       background-color: {{ section.settings.background_color }};
       padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
       padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;

    }
      #shopify-section-{{ section.id }}.collection-banner-main{
         /* height: {{ section.settings.banner_height }}px; edited */
        min-height: 370px;
        width:100%;
        overflow:hidden;
      }
     #shopify-section-{{ section.id }}.collection-banner-side{
       /* height: calc(({{ section.settings.banner_height }}px - 20px) / 2); edited */
       min-height: 170px;
       width: 100%;
     }
     #shopify-section-{{ section.id }}.collection-banner-overlay{
      background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
     }
     #shopify-section-{{ section.id }}.collection-banner-button{
       background-color: {{ section.settings.button_color }};
       color: {{ section.settings.button_text_color }};
     }
     #shopify-section-{{ section.id }}.collection-banner-main.block-count-2 img{
      transition: transform ease 0.6s;
     }
     #shopify-section-{{ section.id }}.collection-banner-main.block-count-2:hover img {
      transform: scale(1.1);
      transition: transform ease-in-out 0.6s;
  }
     #shopify-section-{{ section.id }}.collection-banner-main.block-count-3 img{
      transition: transform ease 0.6s;
     }
     #shopify-section-{{ section.id }}.collection-banner-main.block-count-3:hover img {
      transform: scale(1.1);
      transition: transform ease-in-out 0.6s;
  }
  #shopify-section-{{ section.id }}.collection-banner-side:hover img {
      transition: transform ease 0.6s;
      transform: scale(1.1);
  }
  #shopify-section-{{ section.id }}.collection-banner-side img {
      transition: transform ease 0.6s;
  }
     /* #shopify-section-{{ section.id }}.content-alignment-center{
       text-align:center;
       margin:0 auto;
     }
     #shopify-section-{{ section.id }}.content-alignment-left{
       text-align:left;
     } */
     @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }}.collection-banners-container{
       background-color: {{ section.settings.background_color }};
       padding-top: {{ section.settings.padding_top }}px;
       padding-bottom: {{ section.settings.padding_bottom }}px;

    }
     /* #shopify-section-{{ section.id }}.collection-banner-main{
        height: {{ section.settings.banner_height }}px;
         height: 600px;
        width:50%;
      } edited */

       #shopify-section-{{ section.id }}.collection-banner-main.block-count-2 {
        width: 75%;
        height:550px;
      }

       #shopify-section-{{ section.id }}.collection-banner-main.block-count-3 {
        width: 50%;
        height:550px;
      }


      #shopify-section-{{ section.id }}.collection-banner-side{
       /* height: calc(({{ section.settings.banner_height }}px - 20px) / 2); edited */
       height: 100%;

     }
     }
{% endstyle %}
{{ 'section-grid-banner.css' | asset_url | stylesheet_tag: preload: true }}

<div
  id="shopify-section-{{ section.id }}"
  class="page-width collection-banners-container color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}"
>
  <!-- Main Banner (50%) -->
  {% assign block_count = section.blocks.size %}

  <div id="shopify-section-{{ section.id }}" class="collection-banner-main block-count-{{ block_count }}">
    {% if section.blocks[0].settings.image %}
      {{ section.blocks[0].settings.image | image_url: width: 1500 | image_tag: class: 'collection-banner-image' }}
    {% endif %}

    <div id="shopify-section-{{ section.id }}" class="collection-banner-overlay">
      <div
        id="shopify-section-{{ section.id }}"
        class="
          collection-banner-content content-alignment-{{ section.blocks[0].settings.text_alignment }}
          vertical-align-{{ section.blocks[0].settings.vertical_alignment }}
        "
      >
        <h2 class="h1 collection-banner-title">{{ section.blocks[0].settings.title }}</h2>
        <h4 class="collection-banner-subtitle">{{ section.blocks[0].settings.subtitle }}</h4>
        <div class="collection-banner-description">{{ section.blocks[0].settings.description }}</div>
        {% if section.blocks[0].settings.button_text != blank %}
          <a
            id="shopify-section-{{ section.id }}"
            {% if section.blocks[0].settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.blocks[0].settings.button_link | default: '#' }}"
            {% endif %}
            class="button button-width banner-button content-alignment-{{ section.settings.content_alignment }}"
          >
            {{ section.blocks[0].settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="collection-banners-side">
    {% for block in section.blocks offset: 1 %}
      <div id="shopify-section-{{ section.id }}" class="collection-banner-side">
        {% if block.settings.image %}
          {{ block.settings.image | image_url: width: 1500 | image_tag: class: 'collection-banner-image' }}
        {% endif %}
        <div id="shopify-section-{{ section.id }}" class="collection-banner-overlay">
          <div
            id="shopify-section-{{ section.id }}"
            class="
              collection-banner-content content-alignment-{{ block.settings.text_alignment }}
              vertical-align-{{ block.settings.vertical_alignment }}
            "
          >
            <h2 class="h1 collection-banner-title">{{ block.settings.title }}</h2>
            <h4 class="collection-banner-subtitle">{{ block.settings.subtitle }}</h4>
            <div class="collection-banner-description">{{ block.settings.description }}</div>
            {% if block.settings.button_text != blank %}
              <a
                id="shopify-section-{{ section.id }}"
                {% if block.settings.button_text == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ block.settings.button_link | default: '#' }}"
                {% endif %}
                class="button button-width banner-button content-alignment-{{ section.settings.content_alignment }}"
              >
                {{ block.settings.button_text }}
              </a>
            {% endif %}
            {% if block.settings.discount_text != blank %}
              <div class="collection-banner-discount">{{ block.settings.discount_text }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% comment %}
