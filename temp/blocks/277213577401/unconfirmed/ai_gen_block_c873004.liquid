{% doc %}
  @prompt
    create a slider which have a banner image with scaling effectt and have a text on it and shop now button. mobile and desktop imgaes have different option and ltl and rtl images have also option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-banner-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
    pointer-events: none;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-banner-slider__image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-banner-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform {{ block.settings.scale_duration }}s ease-out;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }}.active .ai-banner-slider__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.scale_amount }});
  }

  .ai-banner-slider__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 20px;
  }

  .ai-banner-slider__content-{{ ai_gen_id }}--left {
    left: {{ block.settings.content_horizontal_offset }}%;
    text-align: left;
  }

  .ai-banner-slider__content-{{ ai_gen_id }}--center {
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
  }

  .ai-banner-slider__content-{{ ai_gen_id }}--right {
    right: {{ block.settings.content_horizontal_offset }}%;
    text-align: right;
  }

  [dir="rtl"] .ai-banner-slider__content-{{ ai_gen_id }}--left {
    left: auto;
    right: {{ block.settings.content_horizontal_offset }}%;
    text-align: right;
  }

  [dir="rtl"] .ai-banner-slider__content-{{ ai_gen_id }}--right {
    right: auto;
    left: {{ block.settings.content_horizontal_offset }}%;
    text-align: left;
  }

  .ai-banner-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-banner-slider__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
  }

  .ai-banner-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-banner-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-banner-slider__navigation-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-banner-slider__arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 3;
    pointer-events: none;
  }

  .ai-banner-slider__arrow-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.8);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    transition: background-color 0.3s ease;
  }

  .ai-banner-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 1);
  }

  .ai-banner-slider__arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-banner-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-slider__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slider__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-banner-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-banner-slider__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }

    .ai-banner-slider__content-{{ ai_gen_id }} {
      max-width: 90%;
    }

    .ai-banner-slider__arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-banner-slider__arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<banner-slider-{{ ai_gen_id }} class="ai-banner-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-slider__wrapper-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
        assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
        assign rtl_desktop_image_key = 'slide_' | append: i | append: '_rtl_desktop_image'
        assign rtl_mobile_image_key = 'slide_' | append: i | append: '_rtl_mobile_image'
        assign heading_key = 'slide_' | append: i | append: '_heading'
        assign text_key = 'slide_' | append: i | append: '_text'
        assign button_text_key = 'slide_' | append: i | append: '_button_text'
        assign button_link_key = 'slide_' | append: i | append: '_button_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign desktop_image = block.settings[desktop_image_key]
        assign mobile_image = block.settings[mobile_image_key]
        assign rtl_desktop_image = block.settings[rtl_desktop_image_key]
        assign rtl_mobile_image = block.settings[rtl_mobile_image_key]
        assign heading = block.settings[heading_key]
        assign text = block.settings[text_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
      %}

      {% if slide_enabled %}
        <div class="ai-banner-slider__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ i }}">
          <div class="ai-banner-slider__image-container-{{ ai_gen_id }}">
            {% if desktop_image or mobile_image or rtl_desktop_image or rtl_mobile_image %}
              <picture>
                {% if rtl_mobile_image %}
                  <source media="(max-width: 749px) and (direction: rtl)" srcset="{{ rtl_mobile_image | image_url: width: 1000 }}">
                {% endif %}
                {% if mobile_image %}
                  <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 1000 }}">
                {% endif %}
                {% if rtl_desktop_image %}
                  <source media="(min-width: 750px) and (direction: rtl)" srcset="{{ rtl_desktop_image | image_url: width: 2000 }}">
                {% endif %}
                {% if desktop_image %}
                  <img
                    src="{{ desktop_image | image_url: width: 2000 }}"
                    alt="{{ desktop_image.alt | escape }}"
                    class="ai-banner-slider__image-{{ ai_gen_id }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                  >
                {% elsif mobile_image %}
                  <img
                    src="{{ mobile_image | image_url: width: 2000 }}"
                    alt="{{ mobile_image.alt | escape }}"
                    class="ai-banner-slider__image-{{ ai_gen_id }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                  >
                {% elsif rtl_desktop_image %}
                  <img
                    src="{{ rtl_desktop_image | image_url: width: 2000 }}"
                    alt="{{ rtl_desktop_image.alt | escape }}"
                    class="ai-banner-slider__image-{{ ai_gen_id }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ rtl_desktop_image.width }}"
                    height="{{ rtl_desktop_image.height }}"
                  >
                {% elsif rtl_mobile_image %}
                  <img
                    src="{{ rtl_mobile_image | image_url: width: 2000 }}"
                    alt="{{ rtl_mobile_image.alt | escape }}"
                    class="ai-banner-slider__image-{{ ai_gen_id }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ rtl_mobile_image.width }}"
                    height="{{ rtl_mobile_image.height }}"
                  >
                {% endif %}
              </picture>
            {% else %}
              <div class="ai-banner-slider__placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                <div class="ai-banner-slider__empty-state-{{ ai_gen_id }}">
                  Next, add images for slide {{ i }}
                </div>
              </div>
            {% endif %}
          </div>

          <div class="ai-banner-slider__content-{{ ai_gen_id }} ai-banner-slider__content-{{ ai_gen_id }}--{{ block.settings.content_alignment }}">
            {% if heading != blank %}
              <h2 class="ai-banner-slider__heading-{{ ai_gen_id }}">{{ heading }}</h2>
            {% endif %}
            {% if text != blank %}
              <div class="ai-banner-slider__text-{{ ai_gen_id }}">{{ text }}</div>
            {% endif %}
            {% if button_text != blank and button_link != blank %}
              <a href="{{ button_link }}" class="ai-banner-slider__button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.show_arrows %}
    <div class="ai-banner-slider__arrows-{{ ai_gen_id }}">
      <button class="ai-banner-slider__arrow-{{ ai_gen_id }} ai-banner-slider__arrow-prev-{{ ai_gen_id }}" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-banner-slider__arrow-{{ ai_gen_id }} ai-banner-slider__arrow-next-{{ ai_gen_id }}" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if block.settings.show_dots %}
    <div class="ai-banner-slider__navigation-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_enabled = block.settings[slide_enabled_key]
        %}
        {% if slide_enabled %}
          <button
            class="ai-banner-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide="{{ i }}"
            aria-label="Go to slide {{ i }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</banner-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-banner-slider__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-banner-slider__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-banner-slider__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-banner-slider__arrow-next-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.startAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const autoplayEnabled = {{ block.settings.autoplay }};
        const autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (autoplayEnabled && this.slides.length > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, autoplaySpeed);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('banner-slider-{{ ai_gen_id }}', BannerSlider{{ ai_gen_id }});
  })();
</script>

