{% doc %}
  @prompt
    Create a social sharing icons block that displays under the add to cart button on the product page. Include sharing buttons for popular platforms such as Facebook, Twitter/X, WhatsApp, and Pinterest. Each icon should be styled to match the store's theme, be clickable, and share the current product URL. The block should be clean, minimal, and mobile-friendly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-share-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-social-share-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    flex-wrap: wrap;
  }

  .ai-social-share-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin: 0;
    font-weight: 500;
  }

  .ai-social-share-icons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.icon_spacing }}px;
    align-items: center;
  }

  .ai-social-share-button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    padding: 0;
  }

  .ai-social-share-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.icon_hover_background }};
    transform: translateY(-2px);
  }

  .ai-social-share-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
    transition: fill 0.3s ease;
  }

  .ai-social-share-button-{{ ai_gen_id }}:hover svg {
    fill: {{ block.settings.icon_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-social-share-container-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
    }
  }
{% endstyle %}

<social-share-{{ ai_gen_id }} class="ai-social-share-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-social-share-container-{{ ai_gen_id }}">
    {% if block.settings.show_label %}
      <p class="ai-social-share-label-{{ ai_gen_id }}">{{ block.settings.label_text }}</p>
    {% endif %}

    <div class="ai-social-share-icons-{{ ai_gen_id }}">
      {% if block.settings.enable_facebook %}
        <a
          href="#"
          class="ai-social-share-button-{{ ai_gen_id }}"
          data-platform="facebook"
          aria-label="Share on Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      {% endif %}

      {% if block.settings.enable_twitter %}
        <a
          href="#"
          class="ai-social-share-button-{{ ai_gen_id }}"
          data-platform="twitter"
          aria-label="Share on X (Twitter)"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      {% endif %}

      {% if block.settings.enable_whatsapp %}
        <a
          href="#"
          class="ai-social-share-button-{{ ai_gen_id }}"
          data-platform="whatsapp"
          aria-label="Share on WhatsApp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
        </a>
      {% endif %}

      {% if block.settings.enable_pinterest %}
        <a
          href="#"
          class="ai-social-share-button-{{ ai_gen_id }}"
          data-platform="pinterest"
          aria-label="Share on Pinterest"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</social-share-{{ ai_gen_id }}>

<script>
  (function() {
    class SocialShare{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.shareButtons = this.querySelectorAll('.ai-social-share-button-{{ ai_gen_id }}');
        this.setupShareLinks();
      }

      setupShareLinks() {
        const productUrl = encodeURIComponent(window.location.href);
        const productTitle = encodeURIComponent(document.title);
        const productImage = this.getProductImage();

        this.shareButtons.forEach((button) => {
          const platform = button.getAttribute('data-platform');
          let shareUrl = '';

          switch (platform) {
            case 'facebook':
              shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${productUrl}`;
              break;
            case 'twitter':
              shareUrl = `https://twitter.com/intent/tweet?url=${productUrl}&text=${productTitle}`;
              break;
            case 'whatsapp':
              shareUrl = `https://wa.me/?text=${productTitle}%20${productUrl}`;
              break;
            case 'pinterest':
              shareUrl = `https://pinterest.com/pin/create/button/?url=${productUrl}&description=${productTitle}&media=${productImage}`;
              break;
          }

          button.setAttribute('href', shareUrl);
        });
      }

      getProductImage() {
        const ogImage = document.querySelector('meta[property="og:image"]');
        if (ogImage) {
          return encodeURIComponent(ogImage.getAttribute('content'));
        }
        return '';
      }
    }

    customElements.define('social-share-{{ ai_gen_id }}', SocialShare{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Social sharing icons",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label text",
      "default": "Share:"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Label size",
      "default": 14
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Platforms"
    },
    {
      "type": "checkbox",
      "id": "enable_facebook",
      "label": "Enable Facebook",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_twitter",
      "label": "Enable X (Twitter)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_whatsapp",
      "label": "Enable WhatsApp",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_pinterest",
      "label": "Enable Pinterest",
      "default": true
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Icon spacing",
      "default": 12
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "icon_hover_background",
      "label": "Hover background color",
      "default": "#c5177c"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_hover_color",
      "label": "Hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Desktop alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Social sharing icons"
    }
  ]
}
{% endschema %}
